# Database
DATABASE_URL="postgresql://zelo:zelo123@localhost:5432/zelo_db?schema=public"

# Criptografia — gere com: openssl rand -base64 32
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"

# Blind Index Pepper — string aleatória, mínimo 8 caracteres
BLIND_INDEX_PEPPER="change_this_pepper_min_8_chars"

# JWT
JWT_SECRET="change_this_jwt_secret_min_16"
JWT_REFRESH_SECRET="change_this_refresh_secret_min_16"
JWT_ACCESS_EXPIRY="30m"
JWT_REFRESH_EXPIRY="7d"

# App
NODE_ENV="development"
PORT=3000
